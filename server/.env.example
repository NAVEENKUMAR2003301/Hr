DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hr_portal?schema=public"
PORT=4000
CLIENT_URL="http://localhost:5173"

JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# Shared passphrase HR staff enter on the Sign Up page — required since every
# sign-up gets full admin access. Pick something only your office knows; leaving
# this unset disables sign-up entirely (existing logins still work).
HR_SIGNUP_CODE="change-me-hr-signup-code"

# Optional — offer/appointment letter emails no-op gracefully if any of these are
# missing (see server/src/services/email.service.js). For Gmail: use an "app password"
# (not your real password) at https://myaccount.google.com/apppasswords, host
# smtp.gmail.com, port 587.
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM=""
